# Google AI Studio (dev) — get your key at aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Keep False to use AI Studio; set True only when switching to Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=False

# CourtListener — free token at https://www.courtlistener.com/sign-in/
COURTLISTENER_API_KEY=your_courtlistener_token_here

# Contact email included in EDGAR User-Agent (required by SEC Fair Access policy)
CONTACT_EMAIL=your_email@example.com
